# CloudFront domain for travel photos (S3: brad-m-travel-pics/{tripId}/{filename}).
# Photo filenames are listed per trip as `photoIds` in src/data/travelData.js.
# Copy to .env locally; set the same variable in Netlify → Environment variables (then redeploy).
# No trailing slash.
VITE_TRAVEL_PHOTOS_BASE_URL=https://dxxxxxxxx.cloudfront.net
